# Deny all traffic between namespace except allowed
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: deny-cross-namespace
  namespace: production
spec:
  podSelector: {}
  policyTypes:
  - Ingress
  - Egress
  ingress:
  - from:
    - namespaceSelector:
        matchLabels:
          name: production  # just pod from namespace production can go inside
    - namespaceSelector:
        matchLabels:
          name: ingress-nginx  # Ingress controller can go inside
