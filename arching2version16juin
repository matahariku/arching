Step 3: SecretProviderClass

apiVersion: secrets-store.csi.x-k8s.io/v1
kind: SecretProviderClass
metadata:
  name: myapp-azure-kv
  namespace: production
spec:
  provider: azure
  parameters:
    usePodIdentity: "false"
    useVMManagedIdentity: "false"
    clientID: ${USER_ASSIGNED_CLIENT_ID}  # Workload Identity Client ID
    keyvaultName: kv-prod-secrets
    cloudName: AzurePublicCloud
    objects: |
      array:
        - |
          objectName: sql-connection-string
          objectType: secret
        - |
          objectName: api-key
          objectType: secret
        - |
          objectName: tls-cert
          objectType: secret
    tenantId: ${AZURE_TENANT_ID}
  
  # Sync ke Kubernetes Secret (agar bisa pakai env var)
  secretObjects:
  - secretName: myapp-secrets
    type: Opaque
    data:
    - objectName: sql-connection-string
      key: connection-string
    - objectName: api-key
      key: api-key

