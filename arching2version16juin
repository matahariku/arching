apiVersion: apps/v1
kind: Deployment
metadata:
  name: myapp
  namespace: production
spec:
  replicas: 1
  selector:
    matchLabels:
      app: myapp
  template:
    metadata:
      labels:
        app: myapp
        # Label important: this trigger mutation webhook for inject token
        azure.workload.identity/use: "true"
    spec:
      serviceAccountName: keyvault-reader-sa  # would the same with step 2
      containers:
      - name: myapp
        image: mcr.microsoft.com/azure-cli:latest
        command: ["/bin/sh", "-c", "sleep 3600"]
        env:
        - name: AZURE_CLIENT_ID
          value: ${USER_ASSIGNED_CLIENT_ID}  # Client ID from step 2
        # Volume token outomatic mounted by mutating webhook
        volumeMounts:
        - name: azure-identity-token
          mountPath: /var/run/secrets/azure/tokens
          readOnly: true
      volumes:
      - name: azure-identity-token
        projected:
          sources:
          - serviceAccountToken:
              path: azure-identity-token
              expirationSeconds: 3600  # Token refresh otomatis
              audience: api://AzureADTokenExchange

