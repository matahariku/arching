Fase 1: Foundation (Identity & Network)

# Step 1: Setup Azure AD Tenant & RBAC

az login
az ad sp create-for-rbac --name "k8s-admin" --role="Contributor"

# Step 2: Resource Group segregation (penting buat governance)

az group create --name rg-management --location southeastasia
az group create --name rg-application --location southeastasia
az group create --name rg-kubernetes --location southeastasia

# Step 3: Virtual Network (VNet) design - K8s need a big  subnet

az network vnet create \
  --name vnet-prod \
  --resource-group rg-application \
  --address-prefix 10.0.0.0/8 \
  --subnet-name subnet-aks \
  --subnet-prefix 10.240.0.0/16
_______

Fase 2: Management Layer (DSC + Monitoring)

# Step 4: Azure Key Vault (untuk simpan K8s secrets, container registry creds)
az keyvault create --name kv-prod-secrets --resource-group rg-management

# Step 5: Log Analytics (Operational Insights modern)
az monitor log-analytics workspace create \
  --resource-group rg-management \
  --name log-aks-prod

# Step 6: Storage Account untuk diagnostics

az storage account create --name stk8sdiag2024 --resource-group rg-management

______

Fase 3: Kubernetes Layer (AKS) - Fokus Utama Lu

# Step 7: Create AKS dengan Azure AD Integration (RBAC enabled)

az aks create \
  --resource-group rg-kubernetes \
  --name aks-prod-cluster \
  --enable-aad \
  --enable-azure-rbac \
  --network-plugin azure \
  --vnet-subnet-id "/subscriptions/.../subnet-aks" \
  --node-count 3 \
  --enable-cluster-autoscaler \
  --min-count 3 \
  --max-count 10 \
  --attach-acr mycontainerregistry \
  --workspace-resource-id "/subscriptions/.../log-aks-prod"

# Step 8: Enable Ingress Controller (NGINX or Application Gateway)

az aks enable-addons \
  --resource-group rg-kubernetes \
  --name aks-prod-cluster \
  --addons ingress-appgw \
  --appgw-name agic-prod

# Step 9: Connect kubectl

az aks get-credentials --resource-group rg-kubernetes --name aks-prod-cluster
Fase 4: Application Layer Integration
Bash

# Step 10: Azure SQL dengan Private Endpoint (biar aman dari K8s)

az sql server create --name sql-prod --resource-group rg-application
az sql db create --server sql-prod --name appdb

# Step 11: Storage Account untuk persistent volumes K8s

az storage account create --name stak8spv --resource-group rg-application

# Step 12: Konfigurasi External Secrets Operator (ambil dari Key Vault ke K8s)

helm repo add external-secrets https://charts.external-secrets.io
helm install external-secrets external-secrets/external-secrets

