Complete Test Script

cat <<'EOF' > test-workload-identity.sh
#!/bin/bash
# Script buat test Workload Identity dari dalam pod

echo "=== Testing Azure Workload Identity ==="

# 1. Check environment variables
echo "AZURE_CLIENT_ID: $AZURE_CLIENT_ID"
echo "AZURE_TENANT_ID: $AZURE_TENANT_ID"

# 2. Check token file exists
TOKEN_FILE="/var/run/secrets/azure/tokens/azure-identity-token"
if [ -f "$TOKEN_FILE" ]; then
    echo "✓ Token file exists"
    echo "Token expiry check:"
    cat $TOKEN_FILE | cut -d '.' -f 2 | base64 -d 2>/dev/null | jq '.exp | todate'
else
    echo "✗ Token file NOT found!"
    exit 1
fi

# 3. Try to get Azure AD token (using curl)
echo "Requesting AAD token for Key Vault..."
AAD_TOKEN=$(curl -s -X POST "https://login.microsoftonline.com/$AZURE_TENANT_ID/oauth2/v2.0/token" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "client_id=$AZURE_CLIENT_ID" \
  -d "scope=https://vault.azure.net/.default" \
  -d "client_assertion=$(cat $TOKEN_FILE)" \
  -d "client_assertion_type=urn:ietf:params:oauth:client-assertion-type:jwt-bearer" \
  -d "grant_type=client_credentials" | jq -r '.access_token')

if [ "$AAD_TOKEN" != "null" ] && [ -n "$AAD_TOKEN" ]; then
    echo "✓ Successfully got AAD token!"
    echo "Token preview: ${AAD_TOKEN:0:50}..."
else
    echo "✗ Failed to get AAD token"
    exit 1
fi

# 4. Try to access Key Vault
echo "Accessing Key Vault..."
KEYVAULT_NAME="kv-prod-secrets"
SECRET_NAME="test-secret"

RESULT=$(curl -s -H "Authorization: Bearer $AAD_TOKEN" \
  "https://$KEYVAULT_NAME.vault.azure.net/secrets/$SECRET_NAME?api-version=7.3")

if echo "$RESULT" | grep -q "value"; then
    echo "✓ Successfully accessed Key Vault!"
    echo "Secret value: $(echo $RESULT | jq -r '.value')"
else
    echo "✗ Failed to access Key Vault"
    echo "Error: $RESULT"
fi
EOF


chmod +x test-workload-identity.sh
kubectl cp test-workload-identity.sh <pod-name>:/tmp/ -n production
kubectl exec -it <pod-name> -n production -- /tmp/test-workload-identity.sh


